# ─────────────────────────────────────────────────────────────
# 조달청 나라장터 MCP 서버 환경변수
# ─────────────────────────────────────────────────────────────

# 공공데이터포털(https://www.data.go.kr) 에서 발급받은 서비스키(Encoding 키 권장).
# 조달청 OpenAPI는 공공데이터포털을 통해 제공되므로, 부동산(mcp-kr-realestate) 서버와
# 동일한 환경변수를 공유할 수 있습니다.
PUBLIC_DATA_API_KEY_ENCODED=your_encoded_service_key_here
# (대안) 전용 변수로 지정할 수도 있습니다:
# G2B_SERVICE_KEY=your_encoded_service_key_here

# 조달청 게이트웨이 호스트(기관코드 1230000). 일반적으로 변경 불필요.
G2B_BASE_HOST=http://apis.data.go.kr/1230000

# 조회 옵션
G2B_NUM_OF_ROWS=100      # 페이지당 결과 수
G2B_MAX_PAGES=50         # 전체 조회 시 최대 페이지 수
G2B_REQUEST_TIMEOUT=60   # 요청 타임아웃(초)

# 캐시 디렉토리(미지정 시 패키지 내부 utils/cache/raw_data 사용)
# MCP_G2B_CACHE_DIR=/path/to/cache

# 서버 설정
HOST=0.0.0.0
PORT=8002
TRANSPORT=stdio          # stdio | streamable-http
LOG_LEVEL=INFO           # DEBUG, INFO, WARNING, ERROR, CRITICAL
MCP_SERVER_NAME=mcp-kr-g2b
